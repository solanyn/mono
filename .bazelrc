# Import Aspect bazelrc presets
import %workspace%/.aspect/bazelrc/bazel7.bazelrc
import %workspace%/.aspect/bazelrc/convenience.bazelrc
import %workspace%/.aspect/bazelrc/correctness.bazelrc
import %workspace%/.aspect/bazelrc/debug.bazelrc
import %workspace%/.aspect/bazelrc/javascript.bazelrc
import %workspace%/.aspect/bazelrc/performance.bazelrc

common --incompatible_enable_proto_toolchain_resolution

# CI configuration
build:ci --stamp
build:ci --workspace_status_command=tools/workspace_status.sh

test:ci --stamp

# Buildbarn remote cache (in-cluster)
build:remote --remote_cache=grpc://buildbarn-frontend.buildbarn.svc.cluster.local:8980
build:remote --remote_timeout=10m
build:remote --remote_local_fallback

try-import %workspace%/user.bazelrc

# Static linking for container images (no glibc dependency)
build:ci --@io_bazel_rules_go//go/config:pure
